# Copy to .env and adjust as needed for local development.
# Never commit the real .env file.

ENV=local

# --- Database (Supabase Postgres) ---
# Use the pooler connection string from Supabase project settings > Database > Connection string.
DATABASE_URL=

# Used only by CI's disposable postgres:16 service container, not local dev.
POSTGRES_USER=talent_match
POSTGRES_PASSWORD=talent_match
POSTGRES_DB=talent_match

# --- Redis (Celery broker/result backend) ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Observability ---
# Leave unset locally: Sentry init is a no-op without a DSN.
SENTRY_DSN=

# --- Auth ---
# Dev-only default below is intentionally insecure. Override in any real environment.
JWT_SECRET_KEY=insecure-dev-only-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth (candidate login) ---
# Leave unset locally: /auth/oauth/google reports 503 until these are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

FRONTEND_URL=http://localhost:3000

# --- Ollama Cloud (LLM parsing + embeddings) ---
# Leave OLLAMA_API_KEY unset locally: resume parsing/embedding will fail clearly until it's set.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_LLM_MODEL=qwen3:cloud
OLLAMA_EMBEDDING_MODEL=bge-m3

# --- Supabase Storage (S3-compatible) ---
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=us-east-1
SUPABASE_STORAGE_BUCKET=resumes

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
