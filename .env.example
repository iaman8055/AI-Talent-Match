# Copy to .env and adjust as needed for local development.
# Never commit the real .env file.

ENV=local

# --- Postgres ---
POSTGRES_USER=talent_match
POSTGRES_PASSWORD=talent_match
POSTGRES_DB=talent_match
DATABASE_URL=postgresql+psycopg://talent_match:talent_match@postgres:5432/talent_match

# --- Redis (Celery broker/result backend) ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Observability ---
# Leave unset locally: Sentry init is a no-op without a DSN.
SENTRY_DSN=

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
