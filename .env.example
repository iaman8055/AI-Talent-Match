# Copy to .env and adjust as needed for local development.
# Never commit the real .env file.

ENV=local

# --- Postgres ---
POSTGRES_USER=talent_match
POSTGRES_PASSWORD=talent_match
POSTGRES_DB=talent_match
DATABASE_URL=postgresql+psycopg://talent_match:talent_match@postgres:5432/talent_match

# --- Redis (Celery broker/result backend) ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Observability ---
# Leave unset locally: Sentry init is a no-op without a DSN.
SENTRY_DSN=

# --- Auth ---
# Dev-only default below is intentionally insecure. Override in any real environment.
JWT_SECRET_KEY=insecure-dev-only-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth (candidate login) ---
# Leave unset locally: /auth/oauth/google reports 503 until these are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

FRONTEND_URL=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
